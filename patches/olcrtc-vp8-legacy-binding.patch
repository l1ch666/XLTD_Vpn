+func TestKCPConnWritesCompatibilityHeadersUntilPinned(t *testing.T) {
+	out := make(chan []byte, 4)
+	first := testEpochHdr(1)
+	second := testEpochHdr(2)
+	conn := newKCPConn(out, 1, first, second)
+
+	n, err := conn.WriteTo([]byte("payload"), nil)
+	if err != nil || n != len("payload") {
+		t.Fatalf("WriteTo() = (%d, %v), want payload length", n, err)
+	}
+	if got := binaryToken(<-out); got != binaryToken(first[:]) {
+		t.Fatalf("first token = 0x%08x, want 0x%08x", got, binaryToken(first[:]))
+	}
+	if got := binaryToken(<-out); got != binaryToken(second[:]) {
+		t.Fatalf("second token = 0x%08x, want 0x%08x", got, binaryToken(second[:]))
+	}
+
+	conn.SetEpochHeaders(second)
+	if _, err := conn.WriteTo([]byte("again"), nil); err != nil {
+		t.Fatalf("WriteTo pinned error = %v", err)
+	}
+	if got := binaryToken(<-out); got != binaryToken(second[:]) {
+		t.Fatalf("pinned token = 0x%08x, want 0x%08x", got, binaryToken(second[:]))
+	}
+}
+
+func binaryToken(frame []byte) uint32 {
+	return binary.BigEndian.Uint32(frame[tokenOff:epochOff])
+}
