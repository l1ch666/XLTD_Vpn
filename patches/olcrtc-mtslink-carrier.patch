diff --git a/internal/engine/mtslink/mtslink.go b/internal/engine/mtslink/mtslink.go
new file mode 100644
index 0000000..8792929
--- /dev/null
+++ b/internal/engine/mtslink/mtslink.go
@@ -0,0 +1,831 @@
+package mtslink
+
+import (
+	"context"
+	"encoding/hex"
+	"errors"
+	"fmt"
+	"os"
+	"strings"
+	"sync"
+	"sync/atomic"
+	"time"
+
+	authMTSLink "github.com/openlibrecommunity/olcrtc/internal/auth/mtslink"
+	"github.com/openlibrecommunity/olcrtc/internal/engine"
+	"github.com/openlibrecommunity/olcrtc/internal/logger"
+	"github.com/pion/interceptor"
+	"github.com/pion/interceptor/pkg/intervalpli"
+	"github.com/pion/webrtc/v4"
+	"github.com/pion/webrtc/v4/pkg/media"
+)
+
+const (
+	defaultSendQueueSize = 16
+	defaultGuestName     = "olcrtc-mtslink"
+	defaultVideoFPS      = 15
+)
+
+var (
+	// valid tiny VP8 keyframe; kept only for legacy diagnostics when
+	// MTS_VIDEO_CODEC=vp8 is explicitly requested.
+	mtslinkVP8TestFrame = []byte{
+		0x30, 0x01, 0x00, 0x9d, 0x01, 0x2a, 0x10, 0x00,
+		0x10, 0x00, 0x00, 0x47, 0x08, 0x85, 0x85, 0x88,
+		0x99, 0x84, 0x88, 0xfc,
+	}
+
+	// MTS Link WebRTC rooms advertise H.264/Opus in the browser. Use a tiny
+	// valid Baseline H.264 access unit for synthetic diagnostics and let the
+	// seichannel transport carry tunnel payloads as H.264 SEI messages.
+	mtslinkH264SPS       = mustDecodeHex("6742c01fdc141fb0110000030001000003001e8f183380")
+	mtslinkH264PPS       = mustDecodeHex("68ce0fc8")
+	mtslinkH264IDRSlices = mustDecodeHexList([]string{
+		"",
+		"",
+		"",
+	})
+	mtslinkH264SEIUUID = [16]byte{0x6d, 0x74, 0x73, 0x6c, 0x69, 0x6e, 0x6b, 0x2d, 0x6f, 0x6c, 0x63, 0x72, 0x74, 0x63, 0x30, 0x31}
+
+	// 15 baseline H.264 Annex-B test frames generated from a moving 320x240
+	// test pattern. The previous 16x16 minimal IDR was technically valid but
+	// MTS Link often kept the participant tile as an avatar because no visible
+	// camera frame was decoded by the web UI.
+	mtslinkVisibleH264AUs = mustDecodeHexList([]string{
+		"",
+		"",
+		"",
+		"",
+		"",
+		"",
+		"",
+		"",
+		"",
+		"",
+		"",
+		"",
+		"",
+		"",
+		"",
+	})
+)
+
+var (
+	ErrSessionClosed       = errors.New("mtslink session closed")
+	ErrByteStreamDisabled  = errors.New("mtslink byte stream unsupported; use videochannel")
+	ErrSessionIDRequired   = errors.New("mtslink session id required")
+	ErrUserIDRequired      = errors.New("mtslink user id required")
+	ErrJoinTokenRequired   = errors.New("mtslink join token required")
+	ErrPublishTokenMissing = errors.New("mtslink publish token required")
+)
+
+type Session struct {
+	name         string
+	roomURL      string
+	sessionID    string
+	userID       string
+	joinToken    string
+	publishToken string
+	conferenceID string
+	did          string
+	pid          string
+	peerID       string
+
+	client *authMTSLink.Client
+
+	pcMu sync.Mutex
+	pc   *webrtc.PeerConnection
+
+	videoTrackMu    sync.RWMutex
+	videoTracks     []webrtc.TrackLocal
+	syntheticTracks []*webrtc.TrackLocalStaticSample
+	syntheticCodec  string
+	onVideoTrack    func(*webrtc.TrackRemote, *webrtc.RTPReceiver)
+	connectedTracks map[webrtc.TrackLocal]bool
+
+	onReconnect     func(*webrtc.DataChannel)
+	shouldReconnect func() bool
+	onEnded         func(string)
+
+	sendQueue chan []byte
+	done      chan struct{}
+	cancel    context.CancelFunc
+
+	videoTestCancel context.CancelFunc
+
+	connected atomic.Bool
+	closed    atomic.Bool
+	closeOnce sync.Once
+	wg        sync.WaitGroup
+}
+
+func New(_ context.Context, cfg engine.Config) (engine.Session, error) {
+	extra := cfg.Extra
+	if extra == nil {
+		extra = map[string]string{}
+	}
+	sessionID := extra[authMTSLink.ExtraSessionID]
+	if sessionID == "" {
+		return nil, ErrSessionIDRequired
+	}
+	userID := extra[authMTSLink.ExtraUserID]
+	if userID == "" {
+		return nil, ErrUserIDRequired
+	}
+	joinToken := extra[authMTSLink.ExtraJoinToken]
+	if joinToken == "" {
+		joinToken = cfg.Token
+	}
+	if joinToken == "" {
+		return nil, ErrJoinTokenRequired
+	}
+	publishToken := extra[authMTSLink.ExtraPublishToken]
+	if publishToken == "" {
+		return nil, ErrPublishTokenMissing
+	}
+	name := cfg.Name
+	if name == "" {
+		name = defaultGuestName
+	}
+	_, cancel := context.WithCancel(context.Background())
+	client := authMTSLink.NewClient(os.Getenv("MTS_COOKIE"))
+	client.GuestName = name
+	client.DeviceID = extra[authMTSLink.ExtraDID]
+	client.UserID = userID
+	return &Session{
+		name:            name,
+		roomURL:         extra[authMTSLink.ExtraRoomURL],
+		sessionID:       sessionID,
+		userID:          userID,
+		joinToken:       joinToken,
+		publishToken:    publishToken,
+		conferenceID:    extra[authMTSLink.ExtraConferenceID],
+		did:             extra[authMTSLink.ExtraDID],
+		pid:             extra[authMTSLink.ExtraPID],
+		client:          client,
+		connectedTracks: make(map[webrtc.TrackLocal]bool),
+		sendQueue:       make(chan []byte, defaultSendQueueSize),
+		done:            make(chan struct{}),
+		cancel:          cancel,
+	}, nil
+}
+
+func (s *Session) Capabilities() engine.Capabilities {
+	return engine.Capabilities{VideoTrack: true}
+}
+
+func (s *Session) Connect(ctx context.Context) error {
+	if s.closed.Load() {
+		return ErrSessionClosed
+	}
+
+	pc, err := s.newPeerConnection()
+	if err != nil {
+		return err
+	}
+
+	// MTS Link SFU validates the shape of the initial SDP. Browser offers from
+	// MTS Link start with a real local audio publisher on mid:0, then one audio
+	// receiver on mid:1. originMid=1 is passed to /rtc/room/.../join.
+	//
+	// The previous build created three recvonly audio m-lines. MTS accepted the
+	// fact that mid:1 was audio, but then rejected the offer with:
+	//   exceeded maximal audio players value 1
+	//
+	// So the initial scaffold must be:
+	//   mid:0 audio sendrecv  - created via a silent local audio track
+	//   mid:1 audio recvonly  - the single allowed audio player
+	//   mid:2 video recvonly  - passive video receiver
+	// Real outgoing camera/tunnel video is added only after initial join via peer
+	// update. For MTS this should be H.264/Opus, not VP8.
+	initialSenders, initialAudioTracks, err := addMTSInitialTransceivers(pc)
+	if err != nil {
+		_ = pc.Close()
+		return err
+	}
+	for _, sender := range initialSenders {
+		s.wg.Add(1)
+		go s.drainRTCP(sender)
+	}
+	if s.silentAudioEnabled() {
+		for _, track := range initialAudioTracks {
+			s.wg.Add(1)
+			go s.pumpSilentAudio(track)
+		}
+	}
+
+	if s.syntheticVideoEnabled() {
+		codec := s.syntheticVideoCodec()
+		track, err := webrtc.NewTrackLocalStaticSample(
+			mtslinkVideoCodecCapability(codec),
+			"mtslink-test-camera",
+			"olcrtc-mtslink-test",
+		)
+		if err != nil {
+			_ = pc.Close()
+			return fmt.Errorf("mtslink create synthetic video track: %w", err)
+		}
+		s.videoTrackMu.Lock()
+		// In diagnostic video-test mode publish only the synthetic camera. The
+		// transport may already have attached a tunnel track before Connect(), and
+		// publishing both creates duplicate video mids. MTS defaults to H.264/Opus;
+		// VP8 is kept only as a legacy override.
+		s.videoTracks = []webrtc.TrackLocal{track}
+		s.syntheticTracks = []*webrtc.TrackLocalStaticSample{track}
+		s.syntheticCodec = codec
+		s.videoTrackMu.Unlock()
+		logger.Infof("mtslink: synthetic %s camera enabled", strings.ToUpper(codec))
+	}
+
+	localTrackCount := 0
+
+	pc.OnTrack(func(track *webrtc.TrackRemote, recv *webrtc.RTPReceiver) {
+		logger.Infof("mtslink: remote track kind=%s codec=%s stream=%s track=%s", track.Kind().String(), track.Codec().MimeType, track.StreamID(), track.ID())
+		if track.Kind() != webrtc.RTPCodecTypeVideo {
+			return
+		}
+		if cb := s.videoTrackHandler(); cb != nil {
+			cb(track, recv)
+		}
+	})
+	pc.OnICEConnectionStateChange(func(state webrtc.ICEConnectionState) {
+		logger.Infof("mtslink ICE state: %s", state.String())
+	})
+	pc.OnConnectionStateChange(func(state webrtc.PeerConnectionState) {
+		logger.Infof("mtslink pc state: %s", state.String())
+		switch state {
+		case webrtc.PeerConnectionStateConnected:
+			s.connected.Store(true)
+		case webrtc.PeerConnectionStateFailed, webrtc.PeerConnectionStateClosed, webrtc.PeerConnectionStateDisconnected:
+			s.connected.Store(false)
+			if !s.closed.Load() && s.onEnded != nil {
+				s.onEnded("mtslink peer connection " + state.String())
+			}
+		}
+	})
+
+	offer, err := s.localOffer(ctx, pc)
+	if err != nil {
+		_ = pc.Close()
+		return err
+	}
+	logger.Infof("mtslink: local offer created tracks=%d summary=%s", localTrackCount, summarizeSDP(offer))
+
+	bootstrap := authMTSLink.Bootstrap{
+		Room:         authMTSLink.RoomInfo{RawURL: s.roomURL, SessionID: s.sessionID},
+		UserID:       s.userID,
+		JoinToken:    s.joinToken,
+		PublishToken: s.publishToken,
+		ConferenceID: s.conferenceID,
+		DID:          s.did,
+		PID:          s.pid,
+	}
+	answer, peerID, err := s.client.JoinSFU(ctx, bootstrap, offer, s.name)
+	if err != nil {
+		_ = pc.Close()
+		return fmt.Errorf("mtslink sfu join: %w", err)
+	}
+	logger.Infof("mtslink: initial SFU answer summary=%s", summarizeSDP(answer))
+	if err := pc.SetRemoteDescription(webrtc.SessionDescription{Type: webrtc.SDPTypeAnswer, SDP: answer}); err != nil {
+		_ = pc.Close()
+		return fmt.Errorf("mtslink set answer: %w", err)
+	}
+
+	s.pcMu.Lock()
+	old := s.pc
+	s.pc = pc
+	s.peerID = peerID
+	s.pcMu.Unlock()
+	if old != nil {
+		_ = old.Close()
+	}
+
+	localTrackCount, err = s.publishLocalVideoTracks(ctx, pc)
+	if err != nil {
+		_ = pc.Close()
+		return err
+	}
+	_ = s.client.AudioVideoControl(ctx, s.conferenceID, localTrackCount > 0)
+	if localTrackCount > 0 && s.peerUpdateEnabled() {
+		if err := s.renegotiatePeerUpdate(ctx, pc, bootstrap, peerID); err != nil {
+			logger.Warnf("mtslink: peer update renegotiation failed: %v", err)
+		}
+	}
+	if localTrackCount > 0 && s.syntheticVideoEnabled() {
+		s.startSyntheticVideo()
+	}
+
+	s.wg.Add(1)
+	go s.pinLoop(peerID)
+	logger.Infof("mtslink: joined session=%s peer=%s localVideoTracks=%d", s.sessionID, peerID, localTrackCount)
+	return nil
+}
+
+func addMTSInitialTransceivers(pc *webrtc.PeerConnection) ([]*webrtc.RTPSender, []*webrtc.TrackLocalStaticSample, error) {
+	// Pion's AddTransceiverFromKind path in this project only supports recvonly,
+	// so we cannot create browser-like audio sendrecv with AddTransceiverFromKind.
+	// Create a silent local Opus track instead; AddTrack gives us the same SDP
+	// shape as browser microphone publishing:
+	//
+	//   mid:0 audio sendrecv
+	//   mid:1 audio recvonly
+	//   mid:2 video recvonly
+	//
+	// This matches MTS validation better than all-recvonly audio sections. MTS
+	// allows only one audio "player" m-line, so creating multiple recvonly audio
+	// sections causes: exceeded maximal audio players value 1.
+	senders := make([]*webrtc.RTPSender, 0, 1)
+	audioTracks := make([]*webrtc.TrackLocalStaticSample, 0, 1)
+	audioTrack, err := webrtc.NewTrackLocalStaticSample(
+		webrtc.RTPCodecCapability{MimeType: webrtc.MimeTypeOpus, ClockRate: 48000, Channels: 2},
+		"mtslink-silent-audio",
+		"olcrtc-mtslink-audio",
+	)
+	if err != nil {
+		return nil, nil, fmt.Errorf("mtslink create initial silent audio track: %w", err)
+	}
+	audioSender, err := pc.AddTrack(audioTrack)
+	if err != nil {
+		return nil, nil, fmt.Errorf("mtslink add initial silent audio track: %w", err)
+	}
+	senders = append(senders, audioSender)
+	audioTracks = append(audioTracks, audioTrack)
+
+	if _, err := pc.AddTransceiverFromKind(webrtc.RTPCodecTypeAudio, webrtc.RTPTransceiverInit{
+		Direction: webrtc.RTPTransceiverDirectionRecvonly,
+	}); err != nil {
+		return nil, nil, fmt.Errorf("mtslink add initial audio recvonly transceiver: %w", err)
+	}
+	if _, err := pc.AddTransceiverFromKind(webrtc.RTPCodecTypeVideo, webrtc.RTPTransceiverInit{
+		Direction: webrtc.RTPTransceiverDirectionRecvonly,
+	}); err != nil {
+		return nil, nil, fmt.Errorf("mtslink add initial video recvonly transceiver: %w", err)
+	}
+	return senders, audioTracks, nil
+}
+
+func (s *Session) publishLocalVideoTracks(ctx context.Context, pc *webrtc.PeerConnection) (int, error) {
+	s.videoTrackMu.RLock()
+	tracks := append([]webrtc.TrackLocal(nil), s.videoTracks...)
+	s.videoTrackMu.RUnlock()
+	if len(tracks) == 0 {
+		return 0, nil
+	}
+
+	published := 0
+	for _, track := range tracks {
+		s.videoTrackMu.Lock()
+		if s.connectedTracks == nil {
+			s.connectedTracks = make(map[webrtc.TrackLocal]bool)
+		}
+		if s.connectedTracks[track] {
+			s.videoTrackMu.Unlock()
+			continue
+		}
+		s.connectedTracks[track] = true
+		s.videoTrackMu.Unlock()
+
+		transceiver, err := pc.AddTransceiverFromTrack(track, webrtc.RTPTransceiverInit{
+			Direction: webrtc.RTPTransceiverDirectionSendonly,
+		})
+		if err != nil {
+			return published, fmt.Errorf("mtslink add local video transceiver after join: %w", err)
+		}
+		published++
+		if sender := transceiver.Sender(); sender != nil {
+			s.wg.Add(1)
+			go s.drainRTCP(sender)
+		}
+	}
+	if published > 0 {
+		logger.Infof("mtslink: local video sendonly tracks attached after initial join=%d", published)
+	}
+	return published, ctx.Err()
+}
+
+func (s *Session) newPeerConnection() (*webrtc.PeerConnection, error) {
+	mediaEngine := &webrtc.MediaEngine{}
+	if err := mediaEngine.RegisterDefaultCodecs(); err != nil {
+		return nil, err
+	}
+	registry := &interceptor.Registry{}
+	intervalPliFactory, err := intervalpli.NewReceiverInterceptor()
+	if err != nil {
+		return nil, err
+	}
+	registry.Add(intervalPliFactory)
+	if err := webrtc.RegisterDefaultInterceptors(mediaEngine, registry); err != nil {
+		return nil, err
+	}
+	api := webrtc.NewAPI(webrtc.WithMediaEngine(mediaEngine), webrtc.WithInterceptorRegistry(registry))
+	pc, err := api.NewPeerConnection(webrtc.Configuration{})
+	if err != nil {
+		return nil, fmt.Errorf("mtslink new peer connection: %w", err)
+	}
+	return pc, nil
+}
+
+func (s *Session) localOffer(ctx context.Context, pc *webrtc.PeerConnection) (string, error) {
+	offer, err := pc.CreateOffer(nil)
+	if err != nil {
+		return "", fmt.Errorf("mtslink create offer: %w", err)
+	}
+	gatherComplete := webrtc.GatheringCompletePromise(pc)
+	if err := pc.SetLocalDescription(offer); err != nil {
+		return "", fmt.Errorf("mtslink set local offer: %w", err)
+	}
+	select {
+	case <-gatherComplete:
+	case <-ctx.Done():
+		return "", ctx.Err()
+	case <-time.After(8 * time.Second):
+		logger.Debugf("mtslink ICE gather timeout; continuing with partial offer")
+	}
+	ld := pc.LocalDescription()
+	if ld == nil {
+		return "", errors.New("mtslink missing local description")
+	}
+	return ld.SDP, nil
+}
+
+func (s *Session) renegotiatePeerUpdate(ctx context.Context, pc *webrtc.PeerConnection, bootstrap authMTSLink.Bootstrap, peerID string) error {
+	if peerID == "" {
+		return nil
+	}
+	select {
+	case <-ctx.Done():
+		return ctx.Err()
+	case <-time.After(300 * time.Millisecond):
+	}
+	offer, err := s.localOffer(ctx, pc)
+	if err != nil {
+		return err
+	}
+	logger.Infof("mtslink: peer update offer summary=%s", summarizeSDP(offer))
+	answer, err := s.client.UpdatePeer(ctx, bootstrap, peerID, offer)
+	if err != nil {
+		return err
+	}
+	logger.Infof("mtslink: peer update answer summary=%s", summarizeSDP(answer))
+	if strings.TrimSpace(answer) == "" {
+		return nil
+	}
+	return pc.SetRemoteDescription(webrtc.SessionDescription{Type: webrtc.SDPTypeAnswer, SDP: answer})
+}
+
+func (s *Session) drainRTCP(sender *webrtc.RTPSender) {
+	defer s.wg.Done()
+	for {
+		if _, _, err := sender.ReadRTCP(); err != nil {
+			return
+		}
+	}
+}
+
+func (s *Session) silentAudioEnabled() bool {
+	v := strings.TrimSpace(os.Getenv("MTS_SILENT_AUDIO"))
+	return v == "" || (v != "0" && !strings.EqualFold(v, "false"))
+}
+
+func (s *Session) pumpSilentAudio(track *webrtc.TrackLocalStaticSample) {
+	defer s.wg.Done()
+	ticker := time.NewTicker(20 * time.Millisecond)
+	defer ticker.Stop()
+	silence := []byte{0xf8, 0xff, 0xfe}
+	for {
+		select {
+		case <-s.done:
+			return
+		case <-ticker.C:
+			if err := track.WriteSample(media.Sample{Data: silence, Duration: 20 * time.Millisecond}); err != nil {
+				logger.Debugf("mtslink silent audio stopped: %v", err)
+				return
+			}
+		}
+	}
+}
+
+func (s *Session) syntheticVideoEnabled() bool {
+	v := strings.TrimSpace(os.Getenv("MTS_VIDEO_TEST"))
+	return v != "" && v != "0" && !strings.EqualFold(v, "false")
+}
+
+func (s *Session) syntheticVideoCodec() string {
+	v := strings.ToLower(strings.TrimSpace(os.Getenv("MTS_VIDEO_CODEC")))
+	switch v {
+	case "vp8":
+		return "vp8"
+	default:
+		return "h264"
+	}
+}
+
+func mtslinkVideoCodecCapability(codec string) webrtc.RTPCodecCapability {
+	if strings.EqualFold(codec, "vp8") {
+		return webrtc.RTPCodecCapability{MimeType: webrtc.MimeTypeVP8, ClockRate: 90000}
+	}
+	return webrtc.RTPCodecCapability{
+		MimeType:    webrtc.MimeTypeH264,
+		ClockRate:   90000,
+		SDPFmtpLine: "level-asymmetry-allowed=1;packetization-mode=1;profile-level-id=42c01f",
+	}
+}
+
+func (s *Session) peerUpdateEnabled() bool {
+	v := strings.TrimSpace(os.Getenv("MTS_PEER_UPDATE"))
+	return v == "" || (v != "0" && !strings.EqualFold(v, "false"))
+}
+
+func (s *Session) startSyntheticVideo() {
+	s.pcMu.Lock()
+	if s.videoTestCancel != nil {
+		s.videoTestCancel()
+	}
+	ctx, cancel := context.WithCancel(context.Background())
+	s.videoTestCancel = cancel
+	s.pcMu.Unlock()
+
+	s.videoTrackMu.RLock()
+	tracks := append([]*webrtc.TrackLocalStaticSample{}, s.syntheticTracks...)
+	codec := s.syntheticCodec
+	s.videoTrackMu.RUnlock()
+	if len(tracks) == 0 {
+		return
+	}
+	if codec == "" {
+		codec = s.syntheticVideoCodec()
+	}
+
+	s.wg.Add(1)
+	go func() {
+		defer s.wg.Done()
+		interval := time.Second / defaultVideoFPS
+		ticker := time.NewTicker(interval)
+		defer ticker.Stop()
+		var frames uint64
+		for {
+			select {
+			case <-ctx.Done():
+				return
+			case <-s.done:
+				return
+			case <-ticker.C:
+				frame := syntheticVideoFrame(codec, frames)
+				for _, tr := range tracks {
+					_ = tr.WriteSample(media.Sample{Data: frame, Duration: interval})
+				}
+				frames++
+				if frames%uint64(defaultVideoFPS*5) == 0 {
+					logger.Infof("mtslink: synthetic %s video frames sent=%d", strings.ToUpper(codec), frames)
+				}
+			}
+		}
+	}()
+}
+
+func syntheticVideoFrame(codec string, n uint64) []byte {
+	if strings.EqualFold(codec, "vp8") {
+		return syntheticVP8Frame(n)
+	}
+	return syntheticH264AccessUnit(n)
+}
+
+func syntheticVP8Frame(n uint64) []byte {
+	// Legacy only. MTS Link normally expects H.264/Opus.
+	frame := make([]byte, 0, len(mtslinkVP8TestFrame)+32)
+	frame = append(frame, mtslinkVP8TestFrame...)
+	frame = append(frame, []byte(fmt.Sprintf("OLCRTC-MTS-TEST-%08d", n))...)
+	return frame
+}
+
+func syntheticH264AccessUnit(n uint64) []byte {
+	if len(mtslinkVisibleH264AUs) > 0 {
+		frame := mtslinkVisibleH264AUs[int(n%uint64(len(mtslinkVisibleH264AUs)))]
+		out := make([]byte, len(frame))
+		copy(out, frame)
+		return out
+	}
+	payload := []byte(fmt.Sprintf("OLCRTC-MTS-H264-TEST-%08d", n))
+	out := make([]byte, 0, len(mtslinkH264SPS)+len(mtslinkH264PPS)+len(payload)+96)
+	out = appendH264StartCode(out, mtslinkH264SPS)
+	out = appendH264StartCode(out, mtslinkH264PPS)
+	out = appendH264StartCode(out, buildMTSLinkSEINAL(payload))
+	for _, idr := range mtslinkH264IDRSlices {
+		out = appendH264StartCode(out, idr)
+	}
+	return out
+}
+
+func buildMTSLinkSEINAL(payload []byte) []byte {
+	userData := make([]byte, 0, len(mtslinkH264SEIUUID)+len(payload))
+	userData = append(userData, mtslinkH264SEIUUID[:]...)
+	userData = append(userData, payload...)
+	rbsp := make([]byte, 0, len(userData)+8)
+	rbsp = appendSEIValue(rbsp, 5)
+	rbsp = appendSEIValue(rbsp, len(userData))
+	rbsp = append(rbsp, userData...)
+	rbsp = append(rbsp, 0x80)
+	escaped := escapeH264RBSP(rbsp)
+	out := make([]byte, 0, 1+len(escaped))
+	out = append(out, 0x06)
+	out = append(out, escaped...)
+	return out
+}
+
+func appendSEIValue(dst []byte, value int) []byte {
+	for value >= 0xff {
+		dst = append(dst, 0xff)
+		value -= 0xff
+	}
+	return append(dst, byte(value))
+}
+
+func appendH264StartCode(dst, nalu []byte) []byte {
+	dst = append(dst, 0x00, 0x00, 0x00, 0x01)
+	return append(dst, nalu...)
+}
+
+func escapeH264RBSP(rbsp []byte) []byte {
+	out := make([]byte, 0, len(rbsp)+8)
+	zeroCount := 0
+	for _, b := range rbsp {
+		if zeroCount >= 2 && b <= 0x03 {
+			out = append(out, 0x03)
+			zeroCount = 0
+		}
+		out = append(out, b)
+		if b == 0x00 {
+			zeroCount++
+		} else {
+			zeroCount = 0
+		}
+	}
+	return out
+}
+
+func mustDecodeHex(value string) []byte {
+	data, err := hex.DecodeString(value)
+	if err != nil {
+		panic(err)
+	}
+	return data
+}
+
+func mustDecodeHexList(values []string) [][]byte {
+	out := make([][]byte, 0, len(values))
+	for _, value := range values {
+		out = append(out, mustDecodeHex(value))
+	}
+	return out
+}
+
+func summarizeSDP(sdp string) string {
+	if sdp == "" {
+		return "empty"
+	}
+	var audio, video, sendonly, sendrecv, recvonly, inactive int
+	for _, line := range strings.Split(sdp, "\n") {
+		line = strings.TrimSpace(line)
+		switch {
+		case strings.HasPrefix(line, "m=audio"):
+			audio++
+		case strings.HasPrefix(line, "m=video"):
+			video++
+		case line == "a=sendonly":
+			sendonly++
+		case line == "a=sendrecv":
+			sendrecv++
+		case line == "a=recvonly":
+			recvonly++
+		case line == "a=inactive":
+			inactive++
+		}
+	}
+	return fmt.Sprintf("audio=%d video=%d sendonly=%d sendrecv=%d recvonly=%d inactive=%d bytes=%d", audio, video, sendonly, sendrecv, recvonly, inactive, len(sdp))
+}
+
+func (s *Session) pinLoop(peerID string) {
+	defer s.wg.Done()
+	if peerID == "" {
+		return
+	}
+	ticker := time.NewTicker(3 * time.Second)
+	defer ticker.Stop()
+	for {
+		select {
+		case <-s.done:
+			return
+		case <-ticker.C:
+			if err := s.client.Pin(context.Background(), peerID); err != nil {
+				logger.Debugf("mtslink pin: %v", err)
+			}
+		}
+	}
+}
+
+func (s *Session) Send([]byte) error { return ErrByteStreamDisabled }
+
+func (s *Session) Close() error {
+	s.closeOnce.Do(func() {
+		s.closed.Store(true)
+		s.connected.Store(false)
+		if s.cancel != nil {
+			s.cancel()
+		}
+		s.pcMu.Lock()
+		if s.videoTestCancel != nil {
+			s.videoTestCancel()
+			s.videoTestCancel = nil
+		}
+		s.pcMu.Unlock()
+		close(s.done)
+		s.pcMu.Lock()
+		pc := s.pc
+		s.pc = nil
+		s.pcMu.Unlock()
+		if pc != nil {
+			_ = pc.Close()
+		}
+		_ = s.client.AudioVideoControl(context.Background(), s.conferenceID, false)
+		stopped := make(chan struct{})
+		go func() {
+			s.wg.Wait()
+			close(stopped)
+		}()
+		select {
+		case <-stopped:
+		case <-time.After(2 * time.Second):
+		}
+	})
+	return nil
+}
+
+func (s *Session) SetReconnectCallback(cb func(*webrtc.DataChannel)) { s.onReconnect = cb }
+func (s *Session) SetShouldReconnect(fn func() bool)                 { s.shouldReconnect = fn }
+func (s *Session) SetEndedCallback(cb func(string))                  { s.onEnded = cb }
+
+func (s *Session) WatchConnection(ctx context.Context) {
+	select {
+	case <-ctx.Done():
+	case <-s.done:
+	}
+}
+
+func (s *Session) CanSend() bool {
+	return !s.closed.Load() && s.connected.Load()
+}
+
+func (s *Session) GetSendQueue() chan []byte { return s.sendQueue }
+func (s *Session) GetBufferedAmount() uint64 { return 0 }
+
+func (s *Session) AddVideoTrack(track webrtc.TrackLocal) error {
+	s.videoTrackMu.Lock()
+	s.videoTracks = append(s.videoTracks, track)
+	s.videoTrackMu.Unlock()
+
+	s.pcMu.Lock()
+	pc := s.pc
+	s.pcMu.Unlock()
+	if pc == nil {
+		return nil
+	}
+
+	s.videoTrackMu.Lock()
+	if s.connectedTracks == nil {
+		s.connectedTracks = make(map[webrtc.TrackLocal]bool)
+	}
+	if s.connectedTracks[track] {
+		s.videoTrackMu.Unlock()
+		return nil
+	}
+	s.connectedTracks[track] = true
+	s.videoTrackMu.Unlock()
+
+	transceiver, err := pc.AddTransceiverFromTrack(track, webrtc.RTPTransceiverInit{
+		Direction: webrtc.RTPTransceiverDirectionSendonly,
+	})
+	if err != nil {
+		return fmt.Errorf("mtslink add video transceiver: %w", err)
+	}
+	if sender := transceiver.Sender(); sender != nil {
+		s.wg.Add(1)
+		go s.drainRTCP(sender)
+	}
+	return nil
+}
+
+func (s *Session) SetVideoTrackHandler(cb func(*webrtc.TrackRemote, *webrtc.RTPReceiver)) {
+	s.videoTrackMu.Lock()
+	defer s.videoTrackMu.Unlock()
+	s.onVideoTrack = cb
+}
+
+func (s *Session) videoTrackHandler() func(*webrtc.TrackRemote, *webrtc.RTPReceiver) {
+	s.videoTrackMu.RLock()
+	defer s.videoTrackMu.RUnlock()
+	return s.onVideoTrack
+}
+
+func init() { //nolint:gochecknoinits // engine registration is the canonical Go pattern for plugins
+	engine.Register("mtslink", New)
+}
